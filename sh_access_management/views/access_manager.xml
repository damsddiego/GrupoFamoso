<odoo>
    <record id="sh_access_manager_form_view" model='ir.ui.view'>
        <field name="name">sh.access.manager.form</field>
        <field name="model">sh.access.manager</field>
        <field name="arch" type="xml">
            <form string="Access Manager">
                <sheet>
                    <h1>
                        <field name="name" default_focus="1" placeholder="Name" required="1"/>
                    </h1>
                    <group>
                        <group>
                            <field name="sh_restriction_type" widget="radio" options="{'horizontal': true}"/>
                            <field name="responsible_user_ids" widget="many2many_tags" invisible="sh_restriction_type == 'group'" required="sh_restriction_type == 'user'"/>
                            <field name="responsible_group_ids" widget="many2many_tags" invisible="sh_restriction_type == 'user'" required="sh_restriction_type == 'group'"/>
                            <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company" />
                            <field name="active_rule"/>
                            <field name="sh_expiry_date" widget="date"/>
                        </group>
                        <group string="Global Restrictions">
                            <field name="sh_readonly" />
                            <field name="sh_disable_developer_mode"/>
                            <field name="sh_global_hide_full_chatter"/>
                             <field name="sh_disable_user_login"/>
                             <field name="sh_is_spreadsheet_installed" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="hide_menu" string="Hide Menu">
                            <field name="sh_hide_menu_ids" no_open="1" options="{'no_create': True, 'no_open': True}">
                                <!-- <list editable="bottom"> -->
                                <list string="Taxes Mapping" editable="bottom">
                                    <field name="complete_name" string="Hide Menu" />
                                    <!-- <field name="sh_child_menu" string="Hide Menu" /> -->
                                </list>
                            </field>
                        </page>
                        <page name="model_access" string="Model Access">
                            <field name="sh_access_model_line">
                                <list editable="bottom">
                                    <field name="model_id" options="{'no_create': True}" optional="show"/>
                                    <field name="action_id" options="{'no_create': True}" optional="show"/>
                                    <field name="report_ids" options="{'no_create': True}" widget="many2many_tags" optional="show"/>
                                    <field name="view_ids" widget="many2many_tags" options="{'no_create': True}" optional="show"/>
                                    <field name="hide_create" optional="show"/>
                                    <!-- <field name="hide_edit"/> -->
                                    <field name="hide_duplicate" optional="show"/>
                                    <field name="hide_delete" optional="show"/>
                                    <field name="hide_archieve" optional="show"/>
                                    <field name="hide_export" optional="show"/>
                                    <field name="sh_hide_action" optional="show"/>
                                    <field name="sh_hide_print" optional="show"/>
                                    <field name="hide_spreadsheet" column_invisible="not parent.sh_is_spreadsheet_installed"/>
                                </list>
                            </field>
                        </page>
                        <page name="field_access" string="Field Access">
                            <field name="sh_field_access_line">
                                <list editable="bottom">
                                    <field name="model_id" options="{'no_create': True}"/>
                                    <field name="field_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                    <field name="readonly"/>
                                    <field name="required"/>
                                    <field name="invisible"/>
                                    <field name="sh_hide_create_edit"/>
                                    <field name="sh_hide_external_links"/>
                                </list>
                            </field>
                        </page>
                        <page name="filter_access" string="Filter / Group By Access">
                            <field name="sh_hide_filter_line">
                                <list editable="bottom">
                                    <field name="model_id" options="{'no_create': True}"/>
                                    <field name="sh_store_filter_data_ids" widget="many2many_tags" />
                                    <field name="sh_store_groupby_data_ids" widget="many2many_tags" />
                                </list>
                            </field>
                        </page>
                        <page name="nv_btn_access" string='Navbar/Button Access'>
                            <field name='sh_navbar_button_line'>
                                <list editable="bottom">
                                    <!-- <field name="model_id" options="{'no_create': True}" domain="[('id','not in',parent.self_model_ids)]" /> -->
                                    <field name="model_id" options="{'no_create': True}"/>
                                    <field name="sh_store_kanban_link_ids" widget="many2many_tags" domain="[('model_id','=',model_id),('sh_node_option','=','kanban_link')]" options="{'no_create': True}" />
                                    <field name="model_name" invisible="1" column_invisible="True"/>
                                    <field name="sh_store_btn_data_ids" widget="many2many_tags" domain="[('model_id','=',model_id),('sh_node_option','=','button')]" options="{'no_create': True}" />
                                    <field name="sh_store_page_data_ids" widget="many2many_tags" domain="[('model_id','=',model_id),('sh_node_option','=','page')]" options="{'no_create': True}" />
                                    <!-- <field name="link_store_model_nodes_ids" widget="many2many_tags" domain="[('model_id','=',model_id),('sh_node_option','=','link')]" options="{'no_create': True}" /> -->
                                </list>
                            </field>
                        </page>
                        <page name="hide_chatter" string="Hide Chatter">
                            <field name="sh_hide_chatter_line">
                                <list editable="bottom">
                                    <field name="model_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                    <field name="hide_full_chatter"/>
                                    <field name="hide_send_msg"/>
                                    <field name="hide_log_notes"/>
                                    <field name="hide_activity"/>
                                    <field name="hide_followers"/>
                                    <field name="hide_attachments"/>
                                </list>
                            </field>
                        </page>
                        <page name="global_restriction_line" string="Global Restrictions">
                            <group>
                                <group string="General Buttons / Actions">
                                    <field name="sh_global_hide_add_property"/>
                                    <field name="sh_global_hide_import"/>
                                    <field name="sh_global_hide_export"/>
                                    <field name="sh_global_hide_print_button"/>
                                    <field name="sh_global_hide_action_button"/>
                                    <field name="sh_global_hide_spreadsheet" invisible="not sh_is_spreadsheet_installed"/>
                                </group>
                                <group string="Filter / Group By">
                                    <field name="sh_global_hide_filter"/>
                                    <field name="sh_global_hide_group"/>
                                    <field name="sh_global_hide_custom_filter_option"/>
                                    <field name="sh_global_hide_custom_group_by_option"/>
                                    <field name="sh_global_hide_favorite_delete"/>
                                </group>
                            </group>
                            <group>
                                <group string="Chatter Options">
                                    <field name="sh_global_hide_send_message"/>
                                    <field name="sh_global_hide_log_note"/>
                                    <field name="sh_global_hide_activity"/>
                                    <field name="sh_global_hide_search_message_icon"/>
                                    <field name="sh_global_hide_attachment_icon"/>
                                    <field name="sh_global_hide_followers_icon"/>
                                    <field name="sh_global_hide_follow_unfollow_button"/>
                                </group>
                                <group string="Field Options">
                                    <field name="sh_global_hide_field_credit_edit"/>
                                </group>
                                <group string="Actions">
                                    <field name="sh_global_hide_create"/>
                                    <field name="sh_global_hide_delete"/>
                                    <field name="sh_global_hide_duplicate"/>
                                    <field name="sh_global_hide_archive"/>
                                    <field name="sh_global_hide_unarchive"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id='sh_access_manager_tree_view' model='ir.ui.view'>
        <field name="name">sh.access.manager.list</field>
        <field name="model">sh.access.manager</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="sh_restriction_type"/>
                <field name="responsible_user_ids" widget="many2many_tags" invisible="sh_restriction_type == 'group'"/>
                <field name="responsible_group_ids" widget="many2many_tags" invisible="sh_restriction_type == 'user'"/>
                <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company" />
                <field name="active_rule"/>
            </list>
        </field>
    </record>

    <record id="sh_access_manager_action" model="ir.actions.act_window">
        <field name="name">Access Management</field>
        <field name="res_model">sh.access.manager</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Access Management
            </p>
        </field>
    </record>
    <menuitem name="Access Management" action="sh_access_manager_action" id="sh_aceess_manager_root" web_icon="sh_access_management,static/description/icon.png" groups="sh_access_management.sh_access_management_manager"/>
</odoo>
