<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_sng_return" model="ir.module.category">
            <field name="name">SNG Return</field>
            <field name="description">Gestion de devoluciones de clientes</field>
            <field name="sequence">16</field>
        </record>

        <record id="group_sng_return_user" model="res.groups">
            <field name="name">Usuario de Devoluciones</field>
            <field name="category_id" ref="module_category_sng_return"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Puede crear y editar sus devoluciones en borrador y consultar historiales.</field>
        </record>

        <record id="group_sng_return_supervisor" model="res.groups">
            <field name="name">Supervisor de Devoluciones</field>
            <field name="category_id" ref="module_category_sng_return"/>
            <field name="implied_ids" eval="[(4, ref('sng_return.group_sng_return_user'))]"/>
            <field name="comment">Puede confirmar, cancelar y ver devoluciones de toda su compania.</field>
        </record>

        <record id="group_sng_return_manager" model="res.groups">
            <field name="name">Gerente de Devoluciones</field>
            <field name="category_id" ref="module_category_sng_return"/>
            <field name="implied_ids" eval="[(4, ref('sng_return.group_sng_return_supervisor'))]"/>
            <field name="comment">Tiene acceso completo a todas las devoluciones de su compania.</field>
        </record>

        <record id="rule_sng_return_user_own" model="ir.rule">
            <field name="name">SNG Return usuario: solo propias</field>
            <field name="model_id" ref="model_sng_return"/>
            <field name="domain_force">[('company_id', 'in', company_ids), ('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('sng_return.group_sng_return_user'))]"/>
        </record>

        <record id="rule_sng_return_supervisor_all" model="ir.rule">
            <field name="name">SNG Return supervisor: todas las de compania</field>
            <field name="model_id" ref="model_sng_return"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('sng_return.group_sng_return_supervisor'))]"/>
        </record>

        <record id="rule_sng_return_manager_all" model="ir.rule">
            <field name="name">SNG Return gerente: todas las de compania</field>
            <field name="model_id" ref="model_sng_return"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('sng_return.group_sng_return_manager'))]"/>
        </record>

        <record id="rule_sng_return_line_user_own" model="ir.rule">
            <field name="name">SNG Return line usuario: solo propias</field>
            <field name="model_id" ref="model_sng_return_line"/>
            <field name="domain_force">[('company_id', 'in', company_ids), ('return_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('sng_return.group_sng_return_user'))]"/>
        </record>

        <record id="rule_sng_return_line_supervisor_all" model="ir.rule">
            <field name="name">SNG Return line supervisor: todas las de compania</field>
            <field name="model_id" ref="model_sng_return_line"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('sng_return.group_sng_return_supervisor'))]"/>
        </record>

        <record id="rule_sng_return_line_manager_all" model="ir.rule">
            <field name="name">SNG Return line gerente: todas las de compania</field>
            <field name="model_id" ref="model_sng_return_line"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('sng_return.group_sng_return_manager'))]"/>
        </record>
    </data>
</odoo>
