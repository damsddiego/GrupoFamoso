<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sng_return_reason_list" model="ir.ui.view">
        <field name="name">sng.return.reason.list</field>
        <field name="model">sng.return.reason</field>
        <field name="arch" type="xml">
            <list string="Motivos de Devolución" editable="top">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_sng_return_reason" model="ir.actions.act_window">
        <field name="name">Motivos de Devolución</field>
        <field name="res_model">sng.return.reason</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Crear un motivo de devolución</p>
            <p>Configure los motivos disponibles al registrar devoluciones de clientes.</p>
        </field>
    </record>
</odoo>
