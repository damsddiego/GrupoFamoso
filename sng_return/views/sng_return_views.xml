<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sng_return_list" model="ir.ui.view">
        <field name="name">sng.return.list</field>
        <field name="model">sng.return</field>
        <field name="arch" type="xml">
            <list string="Devoluciones"
                  decoration-info="state == 'draft'"
                  decoration-success="state == 'confirmed'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="date_request"/>
                <field name="partner_id"/>
                <field name="reason_id"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="line_count"/>
                <field name="total_qty"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_sng_return_form" model="ir.ui.view">
        <field name="name">sng.return.form</field>
        <field name="model">sng.return</field>
        <field name="arch" type="xml">
            <form string="Devolucion de Cliente">
                <header>
                    <button name="action_confirm"
                            string="Confirmar"
                            type="object"
                            class="oe_highlight"
                            groups="sng_return.group_sng_return_supervisor"
                            invisible="state != 'draft'"/>
                    <button name="action_set_to_draft"
                            string="Volver a borrador"
                            type="object"
                            groups="sng_return.group_sng_return_supervisor"
                            invisible="state != 'cancelled'"/>
                    <button name="action_cancel"
                            string="Cancelar"
                            type="object"
                            groups="sng_return.group_sng_return_supervisor"
                            invisible="state == 'cancelled'"/>
                    <button name="action_view_history"
                            string="Historial"
                            type="object"
                            icon="fa-history"
                            invisible="not partner_id"/>
                    <button name="action_generate_credit_note"
                            string="Generar Nota de Crédito"
                            type="object"
                            class="oe_highlight"
                            groups="sng_return.group_sng_return_supervisor"
                            invisible="state != 'confirmed' or credit_note_count &gt; 0"
                            confirm="¿Está seguro de que desea generar la Nota de Crédito para esta devolución?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_credit_notes"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-pencil-square-o"
                                invisible="credit_note_count == 0">
                            <field name="credit_note_count" widget="statinfo" string="Notas de Crédito"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <field name="date_request" readonly="state != 'draft'"/>
                            <field name="reason_id" readonly="state != 'draft'"/>
                            <field name="user_id" widget="many2one_avatar_user" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company" readonly="state != 'draft'"/>
                            <field name="line_count" readonly="1"/>
                            <field name="total_qty" readonly="1"/>
                        </group>
                    </group>
                    <group string="Notas">
                        <field name="notes" nolabel="1" placeholder="Notas adicionales de la devolución..." readonly="state != 'draft'"/>
                    </group>
                    <notebook>
                        <page string="Productos">
                            <field name="line_ids"
                                   context="{'default_partner_id': partner_id, 'default_company_id': company_id}"
                                   readonly="state != 'draft'">
                                <list string="Productos a devolver" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" required="1"/>
                                    <field name="invoice_id" optional="show"/>
                                    <field name="quantity"/>
                                    <field name="uom_id" readonly="1"/>
                                    <field name="invoiced_sale_qty" readonly="1"/>
                                    <field name="previous_return_qty" readonly="1"/>
                                    <field name="credit_note_qty" readonly="1"/>
                                    <field name="available_return_qty" readonly="1"
                                           decoration-danger="available_return_qty &lt; quantity"
                                           decoration-success="available_return_qty &gt;= quantity"/>
                                    <field name="invoiced_sale_order_count" readonly="1" optional="hide"/>
                                    <button name="action_view_history"
                                            string="Historial"
                                            type="object"
                                            icon="fa-history"
                                            class="btn-link"/>
                                    <field name="partner_id" column_invisible="1"/>
                                    <field name="company_id" column_invisible="1"/>
                                    <field name="state" column_invisible="1"/>
                                </list>
                                <form string="Linea de devolucion">
                                    <group>
                                        <group>
                                            <field name="product_id" required="1"/>
                                            <field name="invoice_id"/>
                                            <field name="quantity"/>
                                            <field name="uom_id" readonly="1"/>
                                        </group>
                                        <group>
                                            <field name="invoiced_sale_qty" readonly="1"/>
                                            <field name="previous_return_qty" readonly="1"/>
                                            <field name="credit_note_qty" readonly="1"/>
                                            <field name="available_return_qty" readonly="1"/>
                                            <field name="invoiced_sale_order_count" readonly="1"/>
                                        </group>
                                    </group>
                                    <group>
                                        <field name="notes" placeholder="Notas de la linea..."/>
                                    </group>
                                    <footer>
                                        <button name="action_view_history"
                                                string="Ver historial"
                                                type="object"
                                                class="btn-primary"/>
                                    </footer>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sng_return_search" model="ir.ui.view">
        <field name="name">sng.return.search</field>
        <field name="model">sng.return</field>
        <field name="arch" type="xml">
            <search string="Buscar devoluciones">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="reason_id"/>
                <field name="user_id"/>
                <filter string="Borrador" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmado" name="filter_confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="Cancelado" name="filter_cancelled" domain="[('state', '=', 'cancelled')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Cliente" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Motivo" name="group_reason" context="{'group_by': 'reason_id'}"/>
                    <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Responsable" name="group_user" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sng_return" model="ir.actions.act_window">
        <field name="name">Devoluciones</field>
        <field name="res_model">sng.return</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Crear una devolucion</p>
            <p>Registre productos que un cliente desea devolver y consulte el historial de ordenes facturadas.</p>
        </field>
    </record>
</odoo>
