#. module: sng_invoice_assigned_salesperson
#: model:ir.module.module,description:sng_invoice_assigned_salesperson.module_meta_information
msgid ""
"\n"
"        This module adds the 'assigned_salesperson_id' field to the account.move\n"
"        and sale.order models, related to the partner's assigned salesperson.\n"
"    "
msgstr ""
"\n"
"        Este módulo agrega el campo 'assigned_salesperson_id' a los modelos "
"'account.move'\n"
"        y 'sale.order', relacionado con el vendedor asignado del cliente.\n"
"    "

