<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_credit_limit" model="ir.ui.view">
        <field name="name">account.move.form.inherit.credit.limit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add smart button for stock return picking -->
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button name="action_view_stock_return" type="object"
                        class="oe_stat_button" icon="fa-truck"
                        invisible="not stock_return_picking_id">
                    <field name="stock_return_picking_id" invisible="1"/>
                    <div class="o_stat_info">
                        <span class="o_stat_text">Stock Return</span>
                    </div>
                </button>
            </xpath>

            <!-- Add stock return fields in credit note header -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="has_stock_delivery" invisible="1"/>
                <field name="return_location_required" invisible="1"/>
                <label for="return_location_id" string="Return Warehouse"
                       invisible="move_type != 'out_refund' or not has_stock_delivery"
                       class="{'o_required_modifier': return_location_required}"/>
                <field name="return_location_id"
                       invisible="move_type != 'out_refund' or not has_stock_delivery"
                       required="return_location_required"
                       placeholder="Select warehouse to return products..."
                       options="{'no_create': True}"/>
            </xpath>

            <!-- Add the credit note total field after tax totals -->
            <xpath expr="//field[@name='tax_totals']" position="after">
                <field name="credit_note_total"
                       invisible="move_type != 'out_refund'"
                       readonly="1"
                       widget="monetary"/>
            </xpath>

            <!-- Also add it to the l10n_cr view if it exists -->
            <xpath expr="//field[@name='amount_total_electronic_invoice']" position="after">
                <field name="credit_note_total"
                       invisible="move_type != 'out_refund'"
                       readonly="1"
                       widget="monetary"/>
            </xpath>
        </field>
    </record>

    <!-- Add remaining quantity field to invoice lines -->
    <record id="view_move_form_inherit_credit_limit_lines" model="ir.ui.view">
        <field name="name">account.move.form.inherit.credit.limit.lines</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add remaining_qty_to_refund field in invoice lines tree view -->
            <xpath expr="//field[@name='invoice_line_ids']//field[@name='quantity']" position="after">
                <field name="remaining_qty_to_refund"
                       string="Available to Refund"
                       optional="show"
                       invisible="parent.move_type != 'out_invoice'"
                       readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>