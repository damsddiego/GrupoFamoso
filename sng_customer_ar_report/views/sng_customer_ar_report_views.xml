<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================== -->
    <!--  TREE VIEW                                                          -->
    <!-- ================================================================== -->
    <record id="view_customer_ar_report_tree" model="ir.ui.view">
        <field name="name">customer.ar.report.tree</field>
        <field name="model">customer.ar.report</field>
        <field name="arch" type="xml">
            <list string="Reporte CxC por Cliente" create="false" edit="false" delete="false">
                <field name="partner_code"/>
                <field name="partner_id"/>
                <field name="assigned_salesperson_id" optional="show"/>
                <field name="payment_term_id" optional="show"/>
                <field name="company_id" optional="show" groups="base.group_multi_company"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="invoice_count" optional="show" string="# Facturas"/>
                <field name="paid_invoice_count" optional="show" string="# Pagadas"/>
                <field name="amount_invoiced" sum="Total Facturado"/>
                <field name="amount_due" sum="Total Pendiente"/>
                <field name="avg_days_to_pay" widget="float" options="{'digits': [16, 2]}"/>
                <field name="invoice_date_min" optional="hide"/>
                <field name="invoice_date_max" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ================================================================== -->
    <!--  PIVOT VIEW                                                         -->
    <!-- ================================================================== -->
    <record id="view_customer_ar_report_pivot" model="ir.ui.view">
        <field name="name">customer.ar.report.pivot</field>
        <field name="model">customer.ar.report</field>
        <field name="arch" type="xml">
            <pivot string="Reporte CxC por Cliente">
                <field name="partner_id" type="row"/>
                <field name="amount_invoiced" type="measure"/>
                <field name="amount_due" type="measure"/>
                <field name="avg_days_to_pay" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ================================================================== -->
    <!--  SEARCH VIEW                                                        -->
    <!-- ================================================================== -->
    <record id="view_customer_ar_report_search" model="ir.ui.view">
        <field name="name">customer.ar.report.search</field>
        <field name="model">customer.ar.report</field>
        <field name="arch" type="xml">
            <search string="Buscar Reporte CxC">
                <field name="partner_code"/>
                <field name="partner_id"/>
                <field name="assigned_salesperson_id"/>
                <field name="company_id" groups="base.group_multi_company"/>

                <!-- Quick date filters using invoice_date_max as proxy -->
                <filter name="filter_this_month" string="Este Mes"
                    domain="[
                        ('invoice_date_max', '&gt;=', (context_today()).strftime('%Y-%m-01')),
                        ('invoice_date_min', '&lt;=', (context_today()).strftime('%Y-%m-%d'))
                    ]"/>
                <filter name="filter_last_month" string="Mes Pasado"
                    domain="[
                        ('invoice_date_max', '&gt;=', (context_today() - relativedelta(months=1)).strftime('%Y-%m-01')),
                        ('invoice_date_min', '&lt;=', (context_today() - relativedelta(months=1, day=31)).strftime('%Y-%m-%d'))
                    ]"/>
                <filter name="filter_this_year" string="Este Año"
                    domain="[
                        ('invoice_date_max', '&gt;=', (context_today()).strftime('%Y-01-01')),
                        ('invoice_date_min', '&lt;=', (context_today()).strftime('%Y-%m-%d'))
                    ]"/>

                <separator/>

                <filter name="filter_only_with_balance" string="Solo con Saldo"
                    domain="[('amount_due', '&gt;', 0)]"/>

                <separator/>

                <group expand="0" string="Agrupar por">
                    <filter name="groupby_partner" string="Cliente"
                        context="{'group_by': 'partner_id'}"/>
                    <filter name="groupby_salesperson" string="Vendedor"
                        context="{'group_by': 'assigned_salesperson_id'}"/>
                    <filter name="groupby_company" string="Compañía"
                        context="{'group_by': 'company_id'}"
                        groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================== -->
    <!--  ACTION                                                             -->
    <!-- ================================================================== -->
    <record id="action_customer_ar_report" model="ir.actions.act_window">
        <field name="name">CxC por Cliente</field>
        <field name="res_model">customer.ar.report</field>
        <field name="view_mode">list,pivot</field>
        <field name="search_view_id" ref="view_customer_ar_report_search"/>
        <field name="context">{'search_default_filter_only_with_balance': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay datos de facturación para mostrar.
            </p>
            <p>
                Cree y publique facturas de cliente para ver este reporte.
            </p>
        </field>
    </record>

    <!-- ================================================================== -->
    <!--  MENU                                                               -->
    <!-- ================================================================== -->
    <menuitem
        id="menu_customer_ar_report"
        name="CxC por Cliente"
        parent="account.menu_finance_reports"
        action="action_customer_ar_report"
        sequence="100"/>

</odoo>
