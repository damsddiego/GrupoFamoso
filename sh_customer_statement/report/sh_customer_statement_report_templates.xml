<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="sh_customer_statement_doc">
        <t t-call="web.external_layout">
            <t t-set="o" t-value="o.with_context(lang=o.lang)" />
            <div class="page">
                <div class="oe_structure" />

                <address class="mb-0" t-out="o" t-options='{"widget": "contact", "fields": ["address", "name","vat"], "no_marker": True}'/>
                <center>
                    <span style="font-weight: 800;font-size: 25px;" t-field="o.name" />
                </center>
                <div t-if="not o.env.context.get('sh_hide_dates', True) and (o.start_date or o.end_date)" class="mt-2 mb-2 text-center">
                    <t t-if="o.start_date">
                        <strong>From: </strong><span t-field="o.start_date"/>
                    </t>
                    <t t-if="o.end_date">
                        <strong> To: </strong><span t-field="o.end_date"/>
                    </t>
                </div>
                <t t-if="o.sh_customer_statement_ids">
                    <table class="table table-sm o_main_table mt-3" style="table-layout: fixed; width: 100%; font-size: 11px;">
                        <thead style="display: table-row-group;">
                            <tr>
                                <th style="width: 14%;">Number</th>
                                <th style="width: 10%;">Account</th>
                                <th style="width: 8%;">Date</th>
                                <th style="width: 8%;">Due Date</th>
                                <th style="width: 9%;">Payment Date</th>
                                <th style="width: 10%;">Total Amount</th>
                                <th style="width: 10%;">Paid Amount</th>
                                <th style="width: 13%;">Payment Ref No.</th>
                                <th style="width: 9%;">Balance</th>
                                <th style="width: 9%;">Total Balance</th>
                            </tr>
                        </thead>
                        <tbody class="sale_tbody">
                            <t t-set="amount" t-value="0.0" />
                            <t t-set="paid_amount" t-value="0.0" />
                            <t t-set="balance" t-value="0.0" />
                            <t t-foreach="o.sh_customer_statement_ids.filtered(lambda l: o.env.context.get('sh_hide_dates', True) or ((not o.start_date or (l.sh_customer_invoice_date or l.sh_payment_date) &gt;= o.start_date) and (not o.end_date or (l.sh_customer_invoice_date or l.sh_payment_date) &lt;= o.end_date))).sorted(key=lambda l: (l.sh_customer_invoice_date or l.sh_payment_date))" t-as="line">

                                <t t-set="amount" t-value="amount+line.sh_customer_amount" />
                                <t t-set="paid_amount" t-value="paid_amount+line.sh_customer_paid_amount" />
                                <t t-set="balance" t-value="balance+line.sh_customer_balance" />
                                <t t-if="line.sh_customer_amount == line.sh_customer_balance and line.sh_customer_balance &gt; 0.0 or line.sh_customer_amount == line.sh_customer_balance and line.sh_customer_balance &lt; 0.0">
                                    <tr style="color: #0a8ea4;">
                                        <td><span t-field="line.name" /></td>
                                        <td><span t-field="line.sh_account" /></td>
                                        <td><span t-field="line.sh_customer_invoice_date" /></td>
                                        <td><span t-field="line.sh_customer_due_date" /></td>
                                        <td><span t-field="line.sh_payment_date" /></td>
                                        <td><span t-field="line.sh_customer_amount" /></td>
                                        <td><span t-field="line.sh_customer_paid_amount" /></td>
                                        <td><span t-field="line.sh_payment_reference" /></td>
                                        <td><span t-field="line.sh_customer_balance" /></td>
                                        <td><span t-field="line.sh_total_balance" /></td>
                                    </tr>
                                </t>
                                <t t-if="line.sh_customer_balance == 0.0">
                                    <tr style="color: green;">
                                        <td><span t-field="line.name" /></td>
                                        <td><span t-field="line.sh_account" /></td>
                                        <td><span t-field="line.sh_customer_invoice_date" /></td>
                                        <td><span t-field="line.sh_customer_due_date" /></td>
                                        <td><span t-field="line.sh_payment_date" /></td>
                                        <td><span t-field="line.sh_customer_amount" /></td>
                                        <td><span t-field="line.sh_customer_paid_amount" /></td>
                                        <td><span t-field="line.sh_payment_reference" /></td>
                                        <td><span t-field="line.sh_customer_balance" /></td>
                                        <td><span t-field="line.sh_total_balance" /></td>
                                    </tr>
                                </t>
                                <t t-if="line.sh_customer_amount != line.sh_customer_balance and line.sh_customer_balance &gt; 0.0 or line.sh_customer_amount != line.sh_customer_balance and line.sh_customer_balance &lt; 0.0">
                                    <tr style="color: red;">
                                       <td><span t-field="line.name" /></td>
                                        <td><span t-field="line.sh_account" /></td>
                                        <td><span t-field="line.sh_customer_invoice_date" /></td>
                                        <td><span t-field="line.sh_customer_due_date" /></td>
                                        <td><span t-field="line.sh_payment_date" /></td>
                                        <td><span t-field="line.sh_customer_amount" /></td>
                                        <td><span t-field="line.sh_customer_paid_amount" /></td>
                                        <td><span t-field="line.sh_payment_reference" /></td>
                                        <td><span t-field="line.sh_customer_balance" /></td>
                                        <td><span t-field="line.sh_total_balance" /></td>
                                    </tr>
                                </t>
                            </t>
                            <tr>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td>
                                    <b><span t-esc="'%.2f'%amount" /></b>
                                </td>
                                <td>
                                    <b><span t-esc="'%.2f'%paid_amount" /></b>
                                </td>
                                <td></td>
                                <td>
                                    <b><span t-esc="'%.2f'%balance" /></b>
                                </td>
                                <td></td>
                            </tr>
                        </tbody>
                    </table>
                    <t t-set="lines" t-value="o.sh_customer_statement_ids.filtered(lambda l: o.env.context.get('sh_hide_dates', True) or ((not o.start_date or (l.sh_customer_invoice_date or l.sh_payment_date) &gt;= o.start_date) and (not o.end_date or (l.sh_customer_invoice_date or l.sh_payment_date) &lt;= o.end_date)))" />
                    <t t-set="today" t-value="datetime.date.today()" />
                    
                    <t t-set="standard_lines" t-value="lines.filtered(lambda l: l.sh_customer_amount != 0.0)" />
                    <t t-set="b0_30" t-value="sum(standard_lines.filtered(lambda l: (l.sh_customer_invoice_date or l.sh_payment_date) > today - datetime.timedelta(days=30)).mapped('sh_customer_balance'))" />
                    <t t-set="b31_60" t-value="sum(standard_lines.filtered(lambda l: (l.sh_customer_invoice_date or l.sh_payment_date) &lt;= today - datetime.timedelta(days=30) and (l.sh_customer_invoice_date or l.sh_payment_date) > today - datetime.timedelta(days=60)).mapped('sh_customer_balance'))" />
                    <t t-set="b61_90" t-value="sum(standard_lines.filtered(lambda l: (l.sh_customer_invoice_date or l.sh_payment_date) &lt;= today - datetime.timedelta(days=60) and (l.sh_customer_invoice_date or l.sh_payment_date) > today - datetime.timedelta(days=90)).mapped('sh_customer_balance'))" />
                    <t t-set="b91p" t-value="sum(standard_lines.filtered(lambda l: (l.sh_customer_invoice_date or l.sh_payment_date) &lt;= today - datetime.timedelta(days=90)).mapped('sh_customer_balance'))" />
                    <t t-set="total_bucket" t-value="b0_30 + b31_60 + b61_90 + b91p" />

                    <t t-set="adv_lines" t-value="lines.filtered(lambda l: l.sh_customer_amount == 0.0 or (l.sh_customer_amount != 0.0 and l.sh_customer_balance &lt; 0.0))" />
                    <t t-set="adv0_30" t-value="sum(adv_lines.filtered(lambda l: (l.sh_customer_invoice_date or l.sh_payment_date) > today - datetime.timedelta(days=30)).mapped(lambda l: abs(l.sh_customer_balance)))" />
                    <t t-set="adv31_60" t-value="sum(adv_lines.filtered(lambda l: (l.sh_customer_invoice_date or l.sh_payment_date) &lt;= today - datetime.timedelta(days=30) and (l.sh_customer_invoice_date or l.sh_payment_date) > today - datetime.timedelta(days=60)).mapped(lambda l: abs(l.sh_customer_balance)))" />
                    <t t-set="adv61_90" t-value="sum(adv_lines.filtered(lambda l: (l.sh_customer_invoice_date or l.sh_payment_date) &lt;= today - datetime.timedelta(days=60) and (l.sh_customer_invoice_date or l.sh_payment_date) > today - datetime.timedelta(days=90)).mapped(lambda l: abs(l.sh_customer_balance)))" />
                    <t t-set="adv91p" t-value="sum(adv_lines.filtered(lambda l: (l.sh_customer_invoice_date or l.sh_payment_date) &lt;= today - datetime.timedelta(days=90)).mapped(lambda l: abs(l.sh_customer_balance)))" />
                    <t t-set="total_adv" t-value="adv0_30 + adv31_60 + adv61_90 + adv91p" />

                    <t t-if="o.env.context.get('is_show_aging_bucket') or o.env.context.get('always_show_bucket') or o.env.user.has_group('base.group_portal')">
                        <table class="table table-sm o_main_table mt-4">
                            <thead style="display: table-row-group;">
                                <tr>
                                    <th>Gap Between Days</th>
                                    <th>0-30(Days)</th>
                                    <th>31-60(Days)</th>
                                    <th>61-90(Days)</th>
                                    <th>91+(Days)</th>
                                    <th>Total</th>
                                </tr>

                                <tr>
                                    <td><strong>Balance Amount</strong></td>
                                    <td><t t-esc="'%.2f'%b0_30" /></td>
                                    <td><t t-esc="'%.2f'%b31_60" /></td>
                                    <td><t t-esc="'%.2f'%b61_90" /></td>
                                    <td><t t-esc="'%.2f'%b91p" /></td>
                                    <td><t t-esc="'%.2f'%total_bucket" /></td>
                                </tr>

                                 <tr>
                                    <td><strong>Unallocated Balance Amount</strong></td>
                                    <td><t t-esc="'%.2f'%adv0_30" /></td>
                                    <td><t t-esc="'%.2f'%adv31_60" /></td>
                                    <td><t t-esc="'%.2f'%adv61_90" /></td>
                                    <td><t t-esc="'%.2f'%adv91p" /></td>
                                    <td><t t-esc="'%.2f'%total_adv" /></td>
                                </tr>
                            </thead>
                        </table>
                    </t>
                </t>
            </div>
        </t>
    </template>
    <template id="sh_customer_statement_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="sh_customer_statement.sh_customer_statement_doc" t-lang="o.lang" />
            </t>
        </t>
    </template>
    <record id="action_report_sh_customer_statement" model="ir.actions.report">
        <field name="name">Customer Statement</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-pdf</field>
        <field name="print_report_name">'Customer Statement'</field>
        <field name="report_name">sh_customer_statement.sh_customer_statement_template</field>
        <field name="report_file">sh_customer_statement.sh_customer_statement_template</field>
        <field name="binding_model_id" ref="model_res_partner" />
        <field name="binding_type">report</field>
    </record>
</odoo>
