msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"        \t\t<table border=\"0\" width=\"100%\" cellpadding=\"0\" bgcolor=\"#ededed\" style=\"padding: 20px; background-color: #ededed; border-collapse:separate;\" summary=\"o_mail_notification\">\n"
"                    <tbody>\n"
"                      <!-- HEADER -->\n"
"                      <tr>\n"
"                        <td align=\"center\" style=\"min-width: 590px;\">\n"
"                          <table width=\"590\" border=\"0\" cellpadding=\"0\" bgcolor=\"#875A7B\" style=\"min-width: 590px; background-color: rgb(135,90,123); padding: 20px; border-collapse:separate;\">\n"
"                            <tr>\n"
"                              <td valign=\"middle\">\n"
"                                  <span style=\"font-size:20px; color:white; font-weight: bold;\">\n"
"                                      Customer Overdue Statement\n"
"                                  </span>\n"
"                              </td>\n"
"                              <td valign=\"middle\" align=\"right\">\n"
"                                <img t-att-src=\"'/logo.png?company=%s'%object.get_company().id\" style=\"padding: 0px; margin: 0px; height: auto; width: 80px;\" t-att-alt=\"'%s'%object.get_company().name\"/>\n"
"                              </td>\n"
"                            </tr>\n"
"                          </table>\n"
"                        </td>\n"
"                      </tr>\n"
"\n"
"                      <!-- CONTENT -->\n"
"                      <tr>\n"
"                        <td align=\"center\" style=\"min-width: 590px;\">\n"
"                          <table width=\"590\" border=\"0\" cellpadding=\"0\" bgcolor=\"#ffffff\" style=\"min-width: 590px; background-color: rgb(255, 255, 255); padding: 20px; border-collapse:separate;\">\n"
"                            <tbody>\n"
"                              <td valign=\"top\" style=\"font-family:Arial,Helvetica,sans-serif; color: #555; font-size: 14px;\">\n"
"                                <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"\t\t\t\t\t\t\t    \tDear <t t-out=\"object.name or ''\"/>,\n"
"\t\t\t\t\t\t\t\t\t<br/>\n"
"\t\t\t\t\t\t\t\t\tWe have attached your account overdue statement.\n"
"\t\t\t\t\t\t\t\t\t<br/>\n"
"\t\t\t\t\t\t\t\t\tPlease clear of your overdue payments as soon as possible.\n"
"\t\t\t\t\t\t\t\t\t<br/>\n"
"\t\t\t\t\t\t\t\t\tDownload your overdue statement.\n"
"\t\t\t\t\t\t\t\t\t<br/>\n"
"\t\t\t\t\t\t\t\t\tIf you have any concern regarding overdue statement then feel free to contact us.\n"
"\t\t\t\t\t\t\t\t\t<br/>\n"
"\t\t\t\t\t\t\t\t\t<br/>\n"
"\t\t\t\t\t\t\t    </p>\n"
"                              </td>\n"
"                            </tbody>\n"
"                          </table>\n"
"                        </td>\n"
"                      </tr>\n"
"\n"
"                      <!-- FOOTER -->\n"
"                      <tr>\n"
"                        <td align=\"center\" style=\"min-width: 590px;\">\n"
"                          <table width=\"590\" border=\"0\" cellpadding=\"0\" bgcolor=\"#875A7B\" style=\"min-width: 590px; background-color: rgb(135,90,123); padding: 20px; border-collapse:separate;\">\n"
"                            <tr>\n"
"                              <td valign=\"middle\" align=\"left\" style=\"color: #fff; padding-top: 10px; padding-bottom: 10px; font-size: 12px;\">\n"
"                                <t t-out=\"object.get_company().name or ''\"/><br/>\n"
"                                <t t-out=\"object.get_company().phone or ''\"/>\n"
"                              </td>\n"
"                              <td valign=\"middle\" align=\"right\" style=\"color: #fff; padding-top: 10px; padding-bottom: 10px; font-size: 12px;\">\n"
"                                <t t-if=\"object.get_company().email\">\n"
"                                  <a t-att-href=\"'mailto:%s'%object.get_company().email\" style=\"text-decoration:none; color: white;\"><t t-out=\"object.get_company().email or ''\"/></a><br/>\n"
"                                </t>\n"
"\n"
"                                <t t-if=\"object.get_company().website\">\n"
"                                  <a t-att-href=\"'%s'%object.get_company().website\" style=\"text-decoration:none; color: white;\"><t t-out=\"object.get_company().website or ''\"/></a><br/>\n"
"                                </t>\n"
"                              </td>\n"
"                            </tr>\n"
"                          </table>\n"
"                        </td>\n"
"                      </tr>\n"
"                    </tbody>\n"
"                </table>\n"
