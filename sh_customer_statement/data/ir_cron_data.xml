<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_send_customer_statement_auto" model="ir.cron">
        <field name="name">Auto Send Customer Statements</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="code">model._run_auto_send_customer_statements()</field>
        <field name="state">code</field>
    </record>

    <record id="cron_send_customer_statement_config_auto" model="ir.cron">
        <field name="name">Auto Send Customer Statements Configuration</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="model_id" ref="model_sh_customer_statement_config" />
        <field name="code">model._run_auto_send_customer_statements_config()</field>
        <field name="state">code</field>
    </record>

     <record id="sh_send_customer_statement_action" model="ir.actions.server">
            <field name="name">Send Statement</field>
            <field name="type">ir.actions.server</field>
            <field name="state">code</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="binding_model_id" ref="base.model_res_partner"/>
            <field name="code">
        action = records.send_customer_statement()
            </field>
    </record>

    <!-- <record id="sh_send_customer_overdue_statement_action" model="ir.actions.server">
        <field name="name">Send Overdue Statement</field>
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="model_id" ref="base.model_res_partner" />
        <field name="binding_model_id" ref="base.model_res_partner" />
        <field name="code">
            action.send_customer_overdue_statement()
        </field>
    </record> -->
    <record model="ir.actions.server" id="sh_customer_statement_config_mass_update">
        <field name="name">Mass Update Config</field>
        <field name="type">ir.actions.server</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="binding_model_id" ref="model_res_partner" />
        <field name="state">code</field>
        <field name="code">
                action = records.update_statement_config_manually_()
        </field>
    </record>
    <record id="sh_refresh_statement_action" model="ir.actions.server">
        <field name="name">Compute Statement</field>
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="model_id" ref="base.model_res_partner" />
        <field name="binding_model_id" ref="base.model_res_partner" />
        <field name="code">
            records.sh_compute_action()
        </field>
    </record>
</odoo>
