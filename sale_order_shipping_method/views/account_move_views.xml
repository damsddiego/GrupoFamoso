<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_shipping_method" model="ir.ui.view">
        <field name="name">account.move.form.shipping.method</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="shipping_method" invisible="move_type != 'out_invoice'"/>
            </xpath>
        </field>
    </record>
</odoo>
