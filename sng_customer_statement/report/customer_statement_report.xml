<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Acción de reporte QWeb PDF -->
    <record id="action_report_customer_statement" model="ir.actions.report">
        <field name="name">Estado de Cuenta de Clientes</field>
        <field name="model">sng.customer.statement.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sng_customer_statement.report_customer_statement_doc</field>
        <field name="report_file">sng_customer_statement.report_customer_statement_doc</field>
        <field name="print_report_name">'Estado_Cuenta_Clientes_%s_%s' % (object.date_from, object.date_to)</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>
</odoo>
