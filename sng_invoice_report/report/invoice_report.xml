<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- PDF Report Action -->
    <record id="action_report_invoice_salesperson" model="ir.actions.report">
        <field name="name">Invoice Report by Salesperson</field>
        <field name="model">invoice.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sng_invoice_report.report_invoice_salesperson_document</field>
        <field name="report_file">sng_invoice_report.report_invoice_salesperson_document</field>
        <field name="print_report_name">'Invoice_Report_%s_%s' % (object.date_from, object.date_to)</field>
        <field name="binding_type">report</field>
    </record>
</odoo>
